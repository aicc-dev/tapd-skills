TAPD_CLIENT_ID=your_client_id # 设置成环境变量
TAPD_CLIENT_SECRET=your_client_secret # 设置成环境变量
TAPD_REDIRECT_URI=http://127.0.0.1:8765/callback
# Common scope presets:
# user
# user story#read
# user story#read story#write  <- default
TAPD_SCOPES=user story#read story#write
# Optional. If unset, Codex defaults to ~/.codex/memories/tapd-base/session.json.
# If only the Claude Code config file exists, the default is ~/.claude/tapd-base/session.json.
# TAPD_TOKEN_CACHE=~/.codex/memories/tapd-base/session.json
# TAPD_TOKEN_CACHE=~/.claude/tapd-base/session.json
TAPD_AUTH_BASE_URL=https://www.tapd.cn/oauth/
TAPD_API_BASE_URL=https://api.tapd.cn
